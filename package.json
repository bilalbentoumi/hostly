{
	"name": "hostly",
	"version": "1.0.0",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bilalbentoumi/hostly.git"
	},
	"homepage": "https://gethostly.sh",
	"bugs": "https://github.com/bilalbentoumi/hostly/issues",
	"bin": "dist/cli.js",
	"type": "module",
	"packageManager": "pnpm@11.5.3",
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsc && chmod +x dist/cli.js",
		"dev": "tsc --watch",
		"test": "xo && ava"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"env-paths": "^4.0.0",
		"execa": "^9.6.1",
		"ink": "^5.2.1",
		"ink-select-input": "^6.2.0",
		"ink-spinner": "^5.0.0",
		"ink-text-input": "^6.0.0",
		"meow": "^11.0.0",
		"react": "^18.2.0",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/node": "^25.9.3",
		"@types/react": "^18.0.32",
		"ava": "^5.2.0",
		"chalk": "^5.2.0",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"ts-node": "^10.9.1",
		"typescript": "^5.0.3",
		"xo": "^0.53.1"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"rules": {
			"react/prop-types": "off"
		}
	}
}
